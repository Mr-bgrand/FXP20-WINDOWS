{
  "name": "fxp20-rfid-reader",
  "version": "1.0.7",
  "description": "Zebra FXP20 RFID Reader Desktop Application",
  "main": "dist-electron/main.js",
  "author": "FXP20 Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:middleware\" \"npm run dev:webclient\"",
    "dev:middleware": "cd middleware && npm run dev",
    "dev:webclient": "cd web-client && npm run dev",
    "build:webclient": "cd web-client && npm run build",
    "build:middleware": "cd middleware && npm run build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:all": "npm run build:webclient && npm run build:middleware && npm run build:electron",
    "electron:dev": "npm run build:all && electron .",
    "electron:build": "npm run build:all && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "postinstall": "cd middleware && npm install && cd ../web-client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "winston": "^3.19.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.fxp20.rfid-reader",
    "productName": "FXP20 RFID Reader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "middleware/dist/**/*",
      "middleware/node_modules/**/*",
      "middleware/package.json",
      "web-client/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "java-bridge/build",
        "to": "java-bridge",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "java-bridge/jpos.xml",
        "to": "java-bridge/jpos.xml"
      },
      {
        "from": "java-bridge/jpos_trace.properties",
        "to": "java-bridge/jpos_trace.properties"
      },
      {
        "from": "jpos-driver",
        "to": "jpos-driver",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/jre",
        "to": "jre",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FXP20 RFID Reader"
    }
  }
}
